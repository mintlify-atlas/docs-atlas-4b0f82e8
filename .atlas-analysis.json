  "keyFeatures": [
    "Modern C++ hooking system with clean $modify syntax",
    "Cross-platform mod compatibility (Windows, macOS, Android, iOS)",
    "Built-in settings, events, and resource management",
    "Powerful CLI for project scaffolding and building",
    "Mod dependency resolution and version management",
    "Standardized UI components and layouts",
    "Async/await support with tasks and coroutines",
    "Comprehensive logging and debugging utilities"
  ],
  "publicApiSurface": [
    "$modify macro for hooking classes",
    "Event system (Event, EventListener, EventFilter)",
    "Settings API via mod.json",
    "Mod class for mod lifecycle",
    "Logger for structured logging",
    "Task and Result types for async operations",
    "UI utilities (Popup, Layout, positioning)",
    "Fields system for adding members to classes",
    "geode::cocos namespace for Cocos2d-x integration",
    "Web request utilities (fetch, async downloads)",
    "Memory management utilities",
    "Node IDs and tree traversal",
    "CLI commands (new, build, install, package, publish)"
  ]
